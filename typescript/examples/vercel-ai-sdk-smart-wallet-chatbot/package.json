    "dotenv": "^16.4.5",
    "tsx": "^4.7.1",
    "viem": "^2.24.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "tsx": "^4.7.1"
  }
}
